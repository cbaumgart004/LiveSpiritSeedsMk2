# Copy to .env.local and fill in. NEVER commit .env.local.
# Claude does not enter these for you — create the accounts and paste the keys yourself.

# --- Supabase (Project Settings -> API) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Server-only. Bypasses row-level security — keep it secret, never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Stripe (Developers -> API keys) ---
STRIPE_SECRET_KEY=sk_test_...
# From the Stripe CLI or the webhook endpoint you create in the dashboard.
STRIPE_WEBHOOK_SECRET=whsec_...

# Public base URL of THIS store app (used for Stripe redirect URLs).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
